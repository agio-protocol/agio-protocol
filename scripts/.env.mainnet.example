# ============================================================
# AGIO Protocol — Base Mainnet Configuration
# ============================================================
# Non-secret config only. All private keys are stored in
# macOS Keychain via: python3 scripts/setup_keys.py
# ============================================================

# Network
AGIO_NETWORK=mainnet
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453

# Real token addresses on Base mainnet
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDT_ADDRESS=0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2
DAI_ADDRESS=0x50c5725949A6F0c72E6C4a641F24049A917DB0Cb
WETH_ADDRESS=0x4200000000000000000000000000000000000006
cbETH_ADDRESS=0x2Ae3F1Ec7F1F5012CFEab0185bfc7aa3cf0DEc22

# Uniswap V3 SwapRouter02 on Base
UNISWAP_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481

# Vault seed amount (in USDC)
VAULT_SEED_AMOUNT=500

# Database (production — separate from testnet)
DATABASE_URL=postgresql+asyncpg://agio:password@localhost:5432/agio_mainnet

# Redis (use db 1 to isolate from testnet on db 0)
REDIS_URL=redis://localhost:6379/1

# Basescan API key (get from basescan.org)
BASESCAN_API_KEY=

# Post-deployment: filled automatically by deploy script
VAULT_ADDRESS=
BATCH_SETTLEMENT_ADDRESS=
REGISTRY_ADDRESS=
SWAP_ROUTER_ADDRESS=
